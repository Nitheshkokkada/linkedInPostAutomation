APP_ENV=development
APP_SECRET_KEY=
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8080

# Supabase (free tier)
SUPABASE_DB_URL=jdbc:postgresql://db.{ref}.supabase.co:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_URL=https://{ref}.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=linkedin-ai-images

# Gemini 2.0 Flash (free - get from aistudio.google.com)
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_RPM_LIMIT=12
GEMINI_DAILY_LIMIT=1400

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8080/api/v1/auth/linkedin/callback

# Tavily Search (free tier 1000 req/month)
TAVILY_API_KEY=

# Email notifications (use Gmail SMTP free)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Encryption (32-char key for LinkedIn token encryption)
AES_SECRET_KEY=
